# ============================================================
#  WINDSURF RULES — PRIVACY & BEHAVIOR CONFIGURATION
#  This file controls how Windsurf AI behaves in this project.
#  Place this file in the ROOT of your project folder.
# ============================================================

# ─── PRIVACY & DATA SHARING ─────────────────────────────────

[privacy]

# Never send file contents, folder names, or project structure to any remote server
# for training, telemetry, analytics, or any purpose other than direct code assistance.
telemetry = off
data_collection = off
usage_analytics = off
error_reporting = off
training_data_opt_in = false

# Do not index or cache this project on any remote server
remote_indexing = off
cloud_sync = off

# Do not include file paths, folder names, or code snippets in any telemetry payload
include_file_paths_in_telemetry = false
include_code_in_telemetry = false

# Do not share identity, machine name, or user info
share_user_identity = false
share_machine_info = false


# ─── AI BEHAVIOR RULES ──────────────────────────────────────

[ai_behavior]

# This is a PRIVATE, CONFIDENTIAL project.
# Never reference, store, or transmit project details outside this session.
confidential_project = true

# Never suggest connecting to external services unless explicitly asked
suggest_external_integrations = false

# Never auto-push to GitHub, cloud storage, or any remote endpoint
auto_push = false
auto_sync = false

# Do not auto-generate README files that describe the project publicly
public_readme_generation = false


# ─── CODE STYLE & ASSISTANT PREFERENCES ─────────────────────

[code_style]

language = python
python_version = 3.11
formatter = black
linter = ruff
type_hints = required
docstrings = required

# Always use .env files for API keys — never hardcode secrets
secrets_in_env_only = true
warn_on_hardcoded_secrets = true

# Prefer explicit over implicit
verbose_variable_names = true
avoid_magic_numbers = true


# ─── PROJECT CONTEXT ─────────────────────────────────────────

[project]

# Windsurf must read BUILD_PLAN.md before starting any task.
# This file contains the full phase-by-phase instructions.
read_on_start = ["BUILD_PLAN.md", "CURRENT_PHASE.md"]

# The project is an LLM evaluation framework.
# All work must follow the phase plan defined in BUILD_PLAN.md.
# Do not skip phases or add features not defined in the plan.
follow_phase_plan = true

# Always confirm before deleting files, running installs, or making structural changes
confirm_before_destructive_actions = true

# Preferred model for LLM calls in code
default_llm_judge_model = "llama3.2"
production_llm_judge_model = "qwen2.5:14b"


# ─── FILE & FOLDER RULES ─────────────────────────────────────

[filesystem]

# Never create files outside the project root
restrict_to_project_root = true

# Protect these files — do not modify without explicit instruction
protected_files = [".env", ".windsurfrules", "BUILD_PLAN.md"]

# Always add .env to .gitignore automatically
auto_gitignore_env = true


# ─── WINDSURF NOTES ──────────────────────────────────────────
# If Windsurf does not support a setting above natively,
# treat this file as a behavioral instruction set and follow
# the intent of each rule during this session.
# ============================================================
